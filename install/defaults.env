# Canonical defaults on GitHub (raw). install.sh downloads this file if missing beside install.sh.
# Illustrative WSL layout (prompts use /home/<user>/wsl4ai/ for WSL_BASE).
WSL_BASE=${HOME}/wsl4ai/
WSL_DDBB=${WSL_BASE}ddbb/
WSL_TOOL=${WSL_BASE}tool/
WSL_PROJECTS=${WSL_BASE}projects/
HOST_DDBB=C:/LocalFiles/proyectos/personal/wsl4ai/ddbb/
HOST_PROJECTS=C:/LocalFiles/proyectos/
